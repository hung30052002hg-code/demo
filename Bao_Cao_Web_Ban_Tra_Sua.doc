    <!-- PHỤ LỤC MÃ NGUỒN -->
    <h1 class="page-break">PHỤ LỤC: MỘT SỐ ĐOẠN MÃ NGUỒN QUAN TRỌNG</h1>
    
    <h3>A1. File cấu hình kết nối CSDL Singleton (config/Database.php)</h3>
    <pre>
&lt;?php
class Database {
    private static $instance = null;
    private $conn;

    private $host = 'localhost';
    private $db_name = 'shoptrasua_db';
    private $username = 'root';
    private $password = '';

    private function __construct() {
        try {
            $this->conn = new PDO("mysql:host=" . $this->host . ";dbname=" . $this->db_name, $this->username, $this->password);
            $this->conn->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
            $this->conn->exec("set names utf8mb4");
        } catch(PDOException $exception) {
            echo "Lỗi kết nối cơ sở dữ liệu: " . $exception->getMessage();
            die();
        }
    }

    public static function getInstance() {
        if (!self::$instance) {
            self::$instance = new Database();
        }
        return self::$instance->conn;
    }
}
?&gt;
    </pre>

    <h3 style="margin-top: 2cm;">A2. Front Controller điều hướng (index.php)</h3>
    <pre>
&lt;?php
session_start();
require_once 'config/config.php';
require_once 'config/Database.php';

// Lấy thông tin Controller và Action từ URL, mặc định là home/index
$controllerName = isset($_GET['controller']) ? $_GET['controller'] : 'home';
$actionName = isset($_GET['action']) ? $_GET['action'] : 'index';

// Chuyển đổi tên Controller thành Class Name (VD: home -> HomeController)
$controllerClass = ucfirst($controllerName) . 'Controller';
$controllerFile = 'controllers/' . $controllerClass . '.php';

// Kiểm tra file tồn tại
if (file_exists($controllerFile)) {
    require_once $controllerFile;
    $controller = new $controllerClass();
    
    // Kiểm tra method tồn tại trong class
    if (method_exists($controller, $actionName)) {
        $controller->$actionName();
    } else {
        die('Action không tồn tại');
    }
} else {
    // Xử lý Route cho Admin
    $adminControllerFile = 'controllers/admin/' . $controllerClass . '.php';
    if(file_exists($adminControllerFile)) {
         require_once $adminControllerFile;
         $controller = new $controllerClass();
         if (method_exists($controller, $actionName)) {
             $controller->$actionName();
         }
    } else {
         die('Controller không tồn tại (404 Not Found)');
    }
}
?&gt;
    </pre>

    <h3 class="page-break">A3. Controller xử lý Thanh toán QR (controllers/PaymentController.php)</h3>
    <pre>
&lt;?php
require_once 'models/Order.php';

class PaymentController {
    private $orderModel;

    public function __construct() {
        $this->orderModel = new Order();
    }

    public function pay() {
        // Lấy ID đơn hàng từ URL
        $orderId = isset($_GET['order_id']) ? (int)$_GET['order_id'] : 0;
        
        // Truy vấn thông tin đơn hàng từ CSDL
        $order = $this->orderModel->getById($orderId);

        // Kiểm tra tính hợp lệ
        if (!$order) {
            $_SESSION['error'] = "Đơn hàng không tồn tại.";
            header("Location: " . BASE_URL . "?controller=home&action=index");
            exit;
        }

        // Thông tin cấu hình tài khoản nhận tiền
        $bankInfo = [
            'bank_name' => 'MB Bank - Ngân hàng Quân Đội',
            'account_number' => '0123456789',
            'account_name' => 'VU LE PHI HUNG',
            'memo' => 'DH' . $order['id']
        ];

        // Truyền dữ liệu ra View
        require_once 'views/payment/pay.php';
    }
    
    // Hàm xác nhận đã chuyển khoản
    public function confirm() {
        $orderId = isset($_POST['order_id']) ? (int)$_POST['order_id'] : 0;
        if($orderId > 0) {
             // Cập nhật trạng thái chờ duyệt
             $this->orderModel->updatePaymentStatus($orderId, 'pending_review');
             $_SESSION['success'] = "Đã ghi nhận yêu cầu xác nhận. Chúng tôi sẽ kiểm tra và duyệt đơn hàng sớm nhất.";
        }
        header("Location: " . BASE_URL . "?controller=order&action=history");
    }
}
?&gt;
    </pre>
